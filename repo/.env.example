DATABASE_URL=postgres://civicops:civicops@localhost:5432/civicops
BIND_ADDR=0.0.0.0:8080
SESSION_TTL_SECS=28800
KEK_PATH=/var/civicops/kek.bin
BLOB_DIR=/var/civicops/blobs
OUTBOX_EXPORT_DIR=/var/civicops/outbox
RUST_LOG=info
# Set to "true" only for test/diagnostic use. Off in production.
CIVICOPS_ENABLE_DIAG=false
